PanelWidgetClass RootPanel {
 visible 1
 position 0 0
 size 0.16 0.04
 hexactpos 0
 vexactpos 0
 hexactsize 0
 vexactsize 0
 {
  PanelWidgetClass MarkerBackground {
   ignorepointer 1
   color 0.05 0.05 0.05 0.75
   position 0 0
   size 1 1
   hexactpos 0
   vexactpos 0
   hexactsize 0
   vexactsize 0
   style DayZDefaultPanel
  }
  TextWidgetClass MarkerNameText {
   ignorepointer 1
   color 1 1 1 1
   position 0.02 0
   size 0.96 1
   hexactpos 0
   vexactpos 0
   hexactsize 0
   vexactsize 0
    text "{Player} teleported"
   font "gui/fonts/etelkatextpro"
   "exact text" 1
   "exact text size" 24
   "text halign" center
   "text valign" center
   "text shadow" 1
   "text outline" 1
   "text outline color" 0 0 0 1
   "text outline width" 1
  }
 }
}
