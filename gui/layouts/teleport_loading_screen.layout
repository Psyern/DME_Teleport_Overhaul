FrameWidgetClass DME_TeleportLoadingRoot {
 ignorepointer 1
 position 0 0
 size 1 1
 halign center_ref
 valign center_ref
 hexactpos 0
 vexactpos 0
 hexactsize 0
 vexactsize 0
 {
  ImageWidgetClass Background {
   visible 1
   ignorepointer 1
   position 0 0
   size 1 1
   halign center_ref
   valign center_ref
   hexactpos 0
   vexactpos 0
   hexactsize 0
   vexactsize 0
   image0 ""
   mode opaque
   "src alpha" 1
   "clamp mode" clamp
   "stretch mode" stretch_w_h
   filter 1
  }
  PanelWidgetClass Overlay {
   visible 1
   ignorepointer 1
   color 0 0 0 0.55
   position 0 0
   size 1 1
   halign center_ref
   valign center_ref
   hexactpos 0
   vexactpos 0
   hexactsize 0
   vexactsize 0
   style blank
   {
    TextWidgetClass Title {
     ignorepointer 1
     color 1 1 1 1
         position 0 0.11
         size 1 28
     halign center_ref
         valign bottom_ref
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 1
         text "#STR_DME_TELEPORT_LOADING_PREPARING"
     font "gui/fonts/etelkatextpro22"
     "text halign" center
     "text valign" center
    }
    PanelWidgetClass ProgressBarFrame {
     visible 1
     ignorepointer 1
     color 0 0 0 0.75
     position 0 0.15
     size 0.6 5
     halign center_ref
     valign bottom_ref
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 1
     style DayZDefaultPanel
     {
      ProgressBarWidgetClass ProgressBar {
       visible 1
       ignorepointer 1
       color 0.8 0.12 0.12 0.95
       position 0 0
       size 1 5
       halign center_ref
       hexactpos 0
       vexactpos 0
       hexactsize 0
       vexactsize 1
       style Stamina
      }
     }
    }
   }
  }
 }
}